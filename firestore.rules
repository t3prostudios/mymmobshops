/**
 * VogueVerse Firestore Security Rules
 *
 * CORE PHILOSOPHY:
 * This ruleset implements a robust, owner-centric security model supplemented by a Database Access 
 * Control (DBAC) system for administrative privileges.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user has administrative privileges. */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'bRhr6ftn19SkI8rOlsUqAET81D12' || 
        request.auth.uid == 'zPzGDMpSSLNVBXLKr7H7ab3bhJM2' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(ownerIdField) {
      return isSignedIn() && resource != null && resource.data[ownerIdField] == request.auth.uid;
    }

    function isNewOwner(ownerIdField) {
      return isSignedIn() && request.resource.data[ownerIdField] == request.auth.uid;
    }

    function isUnchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // --- Collection Rules ---

    match /roles_admin/{adminUid} {
      allow get: if isOwner(adminUid);
      allow list, create, update, delete: if false;
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) && isUnchanged('id')) || isAdmin();
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get, list: if isExistingOwner('userId') || isAdmin();
      allow create: if true; // Allow guest checkout creation
      allow update, delete: if isAdmin();
    }

    match /complaints/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /reviews/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /carts/{cartId} {
      allow get, list: if isExistingOwner('ownerId') || isAdmin();
      allow create: if isNewOwner('ownerId');
      allow update: if (isExistingOwner('ownerId') && isUnchanged('ownerId')) || isAdmin();
      allow delete: if isExistingOwner('ownerId') || isAdmin();
    }

    match /carts/{cartId}/cartItems/{cartItemId} {
      allow get, list: if isExistingOwner('cartOwnerId') || isAdmin();
      allow create: if isNewOwner('cartOwnerId');
      allow update: if (isExistingOwner('cartOwnerId') && isUnchanged('cartOwnerId')) || isAdmin();
      allow delete: if isExistingOwner('cartOwnerId') || isAdmin();
    }

    match /emailSubscriptions/{subscriptionId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    
    // Catch-all for other collections
    match /{path=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}