rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOGUEVERSE SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * Enforces user-ownership for personal data and role-based access control (RBAC) 
     * for administrative tasks (POS, Moderation).
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.uid == 'zPzGDMpSSLNVBXLKr7H7ab3bhJM2' ||
        request.auth.uid == 'bRhr6ftn19SkI8rOlsUqAET81D12'
      );
    }

    // --- USER PROFILE & PERSONAL DATA ---

    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /carts/{cartId} {
        allow read, write: if isOwner(userId) || isAdmin();
        match /items/{cartItemId} {
          allow read, write: if isOwner(userId) || isAdmin();
        }
      }

      match /story_submissions/{submissionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if (isExistingOwner(userId) && resource.data.status == 'pending') || isAdmin();
        allow delete: if isExistingOwner(userId) || isAdmin();
      }
    }

    // --- ROOT COLLECTIONS (POS & Public Interaction) ---

    match /orders/{orderId} {
      allow create: if true; // Guests and Users can create orders
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /complaints/{complaintId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- PUBLIC CATALOG & CONTENT (READ ONLY FOR PUBLIC) ---

    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();

      match /variants/{variantId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /hero_slides/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /social_posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /discounts/{discountId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /featured_stories/{storyId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- UTILITY & ADMINISTRATIVE COLLECTIONS ---

    match /subscribers/{subscriberId} {
      allow create: if true;
      allow read, list, update, delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow get: if isOwner(userId);
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}