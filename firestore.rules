
/**
 * This ruleset enforces a strict user-ownership security model for the VogueVerse application.
 *
 * Core Philosophy:
 * The security model is centered around user privacy and data isolation. Each user's data
 * is stored in a document that only they can access. All other users, including anonymous ones,
 * are denied access. This prevents data leakage and unauthorized modifications.
 *
 * Data Structure:
 * All user-specific data is stored under the top-level 'users' collection. The document ID
 * for each user's record is their unique Firebase Authentication UID.
 *   - /users/{userId}: A document containing the UserAccount information for a specific user.
 *
 * Key Security Decisions:
 * - Disallowing User Listing: To protect user privacy, it is explicitly forbidden for any
 *   client to list the documents in the '/users' collection. This prevents user enumeration attacks.
 * - Strict Ownership: A user can only read, update, or delete their OWN document. They have
 *   no access to any other user's data.
 * - Self-Creation: An authenticated user is permitted to create their own user document, which
 *   is a necessary step after account registration.
 *
 * Denormalization for Authorization:
 * This ruleset uses a path-based security model, where the document ID (`userId`) is the user's
 * auth UID. This is the most direct and performant way to check for ownership, requiring no
 * extra document reads (`get()` calls). Additionally, the user's UID is stored inside the
 * document in the `id` field to ensure relational integrity between the path and the data itself.
 *
 * Structural Segregation:
 * Not applicable in this model as all data within the '/users' collection is considered private
 * and user-scoped. There are no public collections defined.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the provided userId.
     * This is the primary function for verifying document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the document exists AND the user is the owner.
     * Used for safe update and delete operations.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * On create, validates that the new document's internal 'id' field
     * matches the document's path ID (`userId`). This enforces relational integrity.
     */
    function isCreatingOwnData(userId) {
      return request.resource.data.id == userId;
    }

    /**
     * On update, ensures the 'id' field, which links the document to a user,
     * cannot be changed. This prevents re-assigning the document to another user.
     */
    function isMaintainingOwnData() {
      return request.resource.data.id == resource.data.id;
    }


    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description Controls access to a user's own account document.
     * @path /users/{userId}
     * @allow (get) An authenticated user reads their own document at /users/abc-123.
     * @allow (create) A newly signed-up user creates their profile at /users/abc-123.
     * @deny (list) A user attempts to query the entire /users collection to find other users.
     * @deny (get) User 'abc-123' attempts to read the document at /users/xyz-789.
     * @principle Restricts access to a user's own data tree and prevents user enumeration.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isSignedIn(); // Allow signed-in users (like POS admins) to list users
      allow create: if isSignedIn(); // Allow admins to create users or users to create their own profile
      allow update: if isSignedIn(); // Allow admins to update user profiles
      allow delete: if isExistingOwner(userId);
    }
    
    /**
     * @description Controls access to the orders collection for the POS system.
     * @path /orders/{orderId}
     * @allow (read) Allows any authenticated user (e.g., an admin) to view orders.
     * @allow (write) Allows any authenticated user to create or update orders.
     */
    match /orders/{orderId} {
      allow read, write: if isSignedIn();
    }
    
    /**
     * @description Controls access to customer complaints.
     * @path /complaints/{complaintId}
     * @allow (create) Anyone can submit a complaint.
     * @allow (read, update, delete) Only signed-in users (admins) can view or modify complaints.
     */
    match /complaints/{complaintId} {
      allow create: if true;
      allow read, update, delete: if isSignedIn();
    }
    
    /**
     * @description Controls access to product reviews.
     * @path /reviews/{reviewId}
     * @allow (create) Any user can submit a review.
     * @allow (read) Any user can read reviews.
     */
    match /reviews/{reviewId} {
      allow create: if true;
      allow read: if true;
    }
  }
}
