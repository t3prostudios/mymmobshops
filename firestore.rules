/**
 * VogueVerse Firestore Security Rules - FORCE ADMIN ACCESS
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Authorization ---
    
    function isHardcodedAdmin() {
      return request.auth != null && (
        request.auth.uid == 'bRhr6ftn19SkI8rOlsUqAET81D12' || 
        request.auth.uid == 'zPzGDMpSSLNVBXLKr7H7ab3bhJM2'
      );
    }

    // --- Collection Rules ---

    // USERS: Admin can see all, users see self
    match /users/{userId} {
      allow get, list: if (request.auth != null && request.auth.uid == userId) || isHardcodedAdmin();
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if (request.auth != null && request.auth.uid == userId) || isHardcodedAdmin();
      allow delete: if isHardcodedAdmin();
    }

    // PRODUCTS: Public read, Admin write
    match /products/{productId} {
      allow read: if true;
      allow write: if isHardcodedAdmin();
    }

    // ORDERS: Admin full access, Guest can create
    match /orders/{orderId} {
      allow read, write: if isHardcodedAdmin();
      allow create: if true; 
    }

    // COMPLAINTS: Admin full access, Public can create
    match /complaints/{id} {
      allow read, write: if isHardcodedAdmin();
      allow create: if true;
    }

    // REVIEWS: Admin full access, Public can create
    match /reviews/{id} {
      allow read, write: if isHardcodedAdmin();
      allow create: if true;
    }

    // CARTS: Owner or Admin
    match /carts/{cartId} {
      allow read, write: if isHardcodedAdmin() || (request.auth != null && resource.data.ownerId == request.auth.uid);
      allow create: if request.auth != null;
    }

    match /carts/{cartId}/cartItems/{cartItemId} {
      allow read, write: if isHardcodedAdmin() || (request.auth != null && request.resource.data.cartOwnerId == request.auth.uid);
    }

    // SUBSCRIPTIONS
    match /emailSubscriptions/{subscriptionId} {
      allow create: if true;
      allow read, write: if isHardcodedAdmin();
    }
    
    // CATCH-ALL
    match /{path=**} {
      allow read, write: if isHardcodedAdmin();
    }
  }
}