{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "registrationDate": { "type": "string", "format": "date-time" },
        "loyaltyPoints": { "type": "number" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "postalCode": { "type": "string" },
        "country": { "type": "string" },
        "prizeLabel": { "type": "string" },
        "prizeExpiry": { "type": "number" }
      },
      "required": ["id", "email", "firstName", "lastName"]
    },
    "Order": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "deliveryMethod": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "object" },
        "orderItems": { "type": "array" },
        "shippingAddress": { "type": "object" }
      },
      "required": ["customerName", "customerEmail", "total", "status", "createdAt"]
    },
    "Complaint": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Complaint",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "issue": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "description": "User profiles and loyalty data."
        }
      },
      {
        "path": "/orders/{orderId}",
        "definition": {
          "entityName": "Order",
          "description": "Root collection for all online and POS orders."
        }
      },
      {
        "path": "/complaints/{complaintId}",
        "definition": {
          "entityName": "Complaint",
          "description": "Root collection for customer issues."
        }
      },
      {
        "path": "/reviews/{reviewId}",
        "definition": {
          "entityName": "Review",
          "description": "Root collection for product reviews."
        }
      },
      {
        "path": "/roles_admin/{userId}",
        "definition": {
          "description": "Used for RBAC. Existence of UID here grants admin privileges."
        }
      }
    ]
  }
}